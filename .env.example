# Wallet address that receives USDC payments
EVM_ADDRESS=0x7c2e102FC6D1FbCd3E62C936d3d394Bd55C949f2

# x402 facilitator URL (default: https://x402.org/facilitator)
FACILITATOR_URL=https://x402.org/facilitator

# Network identifier - Base Sepolia testnet (x402.org only supports testnet currently)
# Format: eip155:<chain_id>  — do not change unless the facilitator adds mainnet support
NETWORK=eip155:84532

# Price per conversion (dollar-prefixed string, e.g. "$0.02")
PRICE=$0.02

# Server port — set automatically by Railway, do not override in production
PORT=8000