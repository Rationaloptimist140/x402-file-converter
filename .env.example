# Wallet address that receives USDC payments
PAYMENT_WALLET_ADDRESS=0x65F204B928a32806FCb364cB8d36B49b647c9f30

# Price per conversion in USDC
PRICE_USDC=0.02

# Network identifier (used in service info response)
NETWORK=base

# Server port (Railway sets this automatically - do not override in production)
PORT=8000

# Environment: production or development (enables hot reload in dev)
ENV=production